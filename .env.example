GEMINI_API_KEY=your_gemini_api_key_here

# Gmail SMTP credentials used to relay contact form submissions.
# EMAIL_USER must be the sending Gmail address.
# EMAIL_PASS must be a 16-character Google App Password — NOT your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
EMAIL_USER=your_gmail_address_here
EMAIL_PASS=your_16_char_app_password_here
